entrypoint = "index.js"
modules = ["nodejs-22", "rust-stable"]
hidden = [".config", "package-lock.json"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json", "package-lock.json"]

[nix]
channel = "stable-24_11"
packages = ["unzip"]

[deployment]
run = ["node", "index.js"]
deploymentTarget = "autoscale"
ignorePorts = false

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start "
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd LUMINA-main && npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start "

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build deunbundle"

[[workflows.workflow]]
name = "Build deunbundle"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = """
cargo build && echo '
  ✓ Binary ready: ./target/debug/deunbundle
  Try: ./target/debug/deunbundle --help'"""

[[ports]]
localPort = 5000
externalPort = 80
